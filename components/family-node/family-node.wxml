<view class="tree-node" id="node-{{node.id}}">

<!-- 如果节点有婚姻关系，按原有方式渲染 -->
<block wx:if="{{node.marriages && node.marriages.length > 0}}">
  <block wx:for="{{node.marriages}}" wx:key="id">
    <!-- 夫妻行 -->
    <view class="couple-row" bindtap="handleCoupleTap" data-husband-id="{{item.husband.id}}" data-wife-id="{{item.wife.id}}">
      <view class="member">
        <image class="avatar {{item.husband.gender}}" src="{{item.husband.avatar}}" />
        <text class="name {{item.husband.highlight ? 'highlight' : ''}}">
          {{item.husband.name}}{{item.husband.adopted ? '（过继）' : ''}}
        </text>
      </view>

      <view class="marriage-link">⇄</view>

      <view class="member">
        <image class="avatar {{item.wife.gender}}" src="{{item.wife.avatar}}" />
        <text class="name {{item.wife.highlight ? 'highlight' : ''}}">
          {{item.wife.name}}{{item.wife.adopted ? '（过继）' : ''}}
        </text>
      </view>
    </view>

    <!-- 子节点容器 -->
    <block wx:if="{{item.children.length > 0}}">
      <view class="children-wrapper">
        <view class="vertical-line"></view>
        <scroll-view scroll-x="true" scroll-with-animation="true" class="children-row-scroll">
          <view class="children-row">
            <block wx:for="{{item.children}}" wx:key="id" wx:for-item="child">
              <view class="child-item">
                <view class="horizontal-line"></view>
                <family-node node="{{child}}" bind:toggle="toggle" id="node-{{child.id}}"/>
              </view>
            </block>
          </view>
        </scroll-view>
      </view>
    </block>
  </block>
</block>

<!-- 如果节点没有婚姻关系（终端节点），直接显示个人信息 -->
<block wx:else>
  <view style="text-align: center; padding: 10px; background: #f8f9fa; border-radius: 5px; margin: 5px;">
    <image class="avatar {{node.gender}}" src="{{node.avatar}}" style="width: 80rpx; height: 112rpx; border-radius: {{node.gender === 'female' ? '50%' : '8rpx'}}; margin-bottom: 5px;" />
    <view style="font-size: 24rpx; color: #333;">{{node.name}}</view>
    <block wx:if="{{node.adopted}}">
      <view style="font-size: 18rpx; color: #666;">（过继）</view>
    </block>
  </view>
</block>

</view>