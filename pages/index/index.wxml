<view class="container">

<!-- 搜索框 -->
<view class="search-bar">
  <input
    placeholder="输入名字搜索 <支持单字>"
    value="{{searchKey}}"
    bindinput="onSearchInput"
    bindconfirm="onSearchConfirm"
    confirm-type="search"
  />
  <button class="search-btn" bindtap="onSearchConfirm">搜索</button>
</view>

<!-- 缩放控制 -->
<view class="zoom-controls">
  <button class="zoom-btn" bindtap="zoomOut">-</button>
  <text class="zoom-text">缩放: {{Math.floor(scale * 100)}}%</text>
  <button class="zoom-btn" bindtap="zoomIn">+</button>
  <button class="reset-btn" bindtap="resetZoom">重置</button>
</view>

<!-- 外层纵向滚动，滚动整棵树 -->
<scroll-view
  scroll-y="true"
  class="tree-container"
  scroll-into-view="{{targetId}}"
  bindtouchstart="onTouchStart"
  bindtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
>
  <block wx:if="{{treeData}}">
    <!-- 横向滚动包裹家族树主体 -->
    <scroll-view
      scroll-x="true"
      scroll-with-animation="true"
      style="width:100%; white-space:nowrap;"
    >
      <view
        style="display:inline-block; transform: scale({{scale}}); transform-origin: 0 0;"
      >
        <family-node
          node="{{treeData}}"
          bind:toggle="onToggleExpand"
          search-key="{{searchKey}}"
        />
      </view>
    </scroll-view>
  </block>
</scroll-view>
</view>