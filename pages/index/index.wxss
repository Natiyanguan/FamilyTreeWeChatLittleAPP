.container {
  padding: 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.search-bar input {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
}

/* 缩放控制样式 */
.zoom-controls {
  display: flex;
  align-items: center;
  gap: 15rpx;
  background: rgba(7, 193, 96, 0.1);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(7, 193, 96, 0.3);
  margin-bottom: 20rpx;
}

.zoom-btn {
  width: 60rpx;
  height: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  background-color: #07c160;
  color: white;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.zoom-text {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 500;
  min-width: 120rpx;
  text-align: center;
}

.reset-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  background-color: #ff9500;
  color: white;
  border: none;
  border-radius: 8rpx;
}

.tree-container {
  height: 100vh;
}

.node {
  margin-left: 40rpx;
}

.member {
  display: flex;
  align-items: center;
  margin: 10rpx 0;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}